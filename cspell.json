{
  // cspell 配置文件版本号,0.2 是当前主流版本
  "version": "0.2",
  // 词典主语言:英文,作为拼写检查的基础词典
  "language": "en",
  // 项目自定义白名单:这些单词不会被 cspell 视为拼写错误
  // 主要收录项目用到的技术栈、库名、工具名等专有名词
  "words": [
    "langchain", // LangChain — LLM 应用开发框架
    "langgraph", // LangGraph — LangChain 之上的状态机式 Agent 编排框架
    "deepagents", // DeepAgents — 项目使用的 Agent 抽象库
    "pgvector", // pgvector — PostgreSQL 的向量检索扩展,用于向量相似度搜索
    "zustand", // Zustand — 轻量级 React 状态管理库
    "shadcn", // shadcn/ui — 基于 Radix UI + Tailwind 的组件库方案
    "tailwindcss", // Tailwind CSS — 原子化 CSS 框架
    "vite", // Vite — 前端构建工具
    "nestjs", // NestJS — 后端 Node.js 框架
    "typecheck", // 类型检查 — 项目脚本命令名
    "vitest", // Vitest — Vite 原生测试框架
    "pydantic", // Pydantic — Python 数据验证库
    "psycopg", // psycopg — PostgreSQL 的 Python 驱动
    "httpx", // HTTPX — Python 异步 HTTP 客户端
    "ollama", // Ollama — 本地大模型运行环境
    "vllm", // vLLM — 高性能 LLM 推理服务
    "monorepo", // monorepo — 单仓多包代码组织方式
    "turborepo" // Turborepo — monorepo 构建编排工具
  ],
  // 忽略路径:这些目录不参与拼写检查
  // 避免对第三方代码、构建产物、锁文件等产生大量误报
  "ignorePaths": [
    "node_modules", // 前端依赖目录
    ".git", // Git 元数据目录
    "dist", // 构建产物目录
    ".venv", // Python 虚拟环境目录(包含大量第三方库源码)
    "__pycache__", // Python 字节码缓存目录
    "pnpm-lock.yaml", // pnpm 锁文件(含哈希等无需检查的内容)
    "uv.lock" // uv(Python 包管理器)锁文件
  ]
}
