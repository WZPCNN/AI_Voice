# ============================================================
# API Server 环境变量示例
# 复制为 .env 并填入真实值
# ============================================================

# API keys（可选，数据库配置优先级更高）
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-your-key-here

# Database
DATABASE_URL=postgresql://agent:agent_dev_2026@localhost:5432/ai_voice

# Redis
REDIS_URL=redis://localhost:6379

# ============================================================
# 认证配置（P0 新增）
# ============================================================

# JWT 密钥 — 用 `openssl rand -hex 32` 生成
JWT_SECRET=please-generate-a-32-byte-hex-secret

# JWT 过期时间
JWT_EXPIRES_IN=7d

# API Key 加密密钥 — 用 `openssl rand -hex 32` 生成（32 字节 = 64 hex 字符）
ENCRYPTION_KEY=please-generate-a-32-byte-hex-secret

# ============================================================
# 服务配置（P0 新增）
# ============================================================

# CORS 允许来源（逗号分隔多个域名）
CORS_ORIGIN=http://localhost:3000

# 服务监听端口
PORT=4000
