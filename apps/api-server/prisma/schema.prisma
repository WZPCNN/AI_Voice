generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 应用工作模式枚举
enum Mode {
  EXECUTE
  PLAN
  MULTI
  SKILLS
  MCP
}

// 消息角色枚举
enum MessageRole {
  USER
  ASSISTANT
  TOOL
  AGENT
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  password  String?   @db.VarChar(255)
  role      String    @default("user") @db.VarChar(20)
  avatarUrl String?   @map("avatar_url") @db.Text
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  sessions   Session[]
  configs    AgentConfig[]
  mcpServers McpServer[]

  @@map("users")
}

model Session {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  title          String    @default("New Session") @db.VarChar(500)
  modelId        String    @default("gpt-4o") @map("model_id") @db.VarChar(100)
  mode           String    @default("execute") @db.VarChar(50)
  contextSummary String?   @map("context_summary") @db.Text
  metadata       Json      @default("{}") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("sessions")
}

model Message {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String   @db.VarChar(50)
  content   String   @db.Text
  metadata  Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

model AgentConfig {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  modelProvider String   @default("openai") @map("model_provider") @db.VarChar(50)
  modelName     String   @default("gpt-4o") @map("model_name") @db.VarChar(100)
  temperature   Float    @default(0.7) @db.Real
  maxTokens     Int      @default(4096) @map("max_tokens")
  tools         String[] @default([])
  systemPrompt  String?  @map("system_prompt") @db.Text
  apiKey        String?  @map("api_key") @db.Text
  baseUrl       String?  @map("base_url") @db.Text
  isSelected    Boolean  @default(false) @map("is_selected")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

// MCP 服务器配置 — 用户可配置外部 Model Context Protocol 服务器
model McpServer {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(255)
  transport String   @default("stdio") @db.VarChar(20)
  command   String?  @db.Text
  url       String?  @db.Text
  env       Json?    @db.JsonB
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mcp_servers")
}
