{
  "compilerOptions": {
    "strict": true,
    "target": "ES2023",
    "module": "nodenext",
    "lib": ["ES2023"],
    "outDir": "./dist",
    "rootDir": "./src",
    "experimentalDecorators": true,
    "moduleResolution": "nodenext",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
